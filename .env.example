# Valores usados como referência para desenvolvimento e deploy.
MOVEPREDICT_GTFS_DATA_DIR=./data-exploration/data/raw
MOVEPREDICT_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=/api
API_PROXY_TARGET=http://localhost:8000
MOVEPREDICT_GEOCODING_URL=https://nominatim.openstreetmap.org
MOVEPREDICT_GEOCODING_USER_AGENT=MovePredict-BH/0.1 (+https://github.com/atos-og/movepredict-bh)
MOVEPREDICT_JOURNEY_PLANNER_URL=http://otp:8080/otp/gtfs/v1
MOVEPREDICT_GTFS_RT_ALERTS_URL=
OTP_JAVA_MAX_HEAP=4G

# Para acessar pelo celular na mesma rede Wi-Fi, copie este arquivo para .env
# e troque apenas o host permitido pelo IPv4 atual (resultado de ipconfig).
# MOVEPREDICT_CORS_ORIGINS=http://localhost:3000,http://<IP-DO-COMPUTADOR>:3000
# O frontend usa /api e encaminha internamente para o backend; nenhum IP e exposto no build.
